{
   "$schema": "https://json-schema.org/draft/2020-12/schema",
   "$id": "https://github.com/hpc-gridware/clusterscheduler/tree/master/source/dist/util/resources/json-schemas/common.schema.json",
   "$defs": {
      "descriptionLine": {
         "type": "object",
         "required": [
            "line"
         ],
         "properties": {
            "line": {
               "type": "string",
               "minLength": 1
            }
         },
         "additionalProperties": false
      },
      "descriptionBlock": {
         "type": "array",
         "minItems": 1,
         "items": {
            "$ref": "#/$defs/descriptionLine"
         }
      },
      "flagName": {
         "type": "string",
         "enum": [
            "CONFIGURE",
            "HASH",
            "JGDI_CONF",
            "JGDI_HIDDEN",
            "JGDI_RO",
            "PRIMARY_KEY",
            "SPOOL",
            "SPOOL_PROJECT",
            "SPOOL_SUBLIST",
            "UNIQUE"
         ]
      },
      "flag": {
         "type": "object",
         "required": [
            "name"
         ],
         "properties": {
            "name": {
               "$ref": "#/$defs/flagName"
            }
         },
         "additionalProperties": false
      },
      "flags": {
         "type": "array",
         "uniqueItems": true,
         "items": {
            "$ref": "#/$defs/flag"
         }
      },
      "attributeType": {
         "type": "string",
         "description": "Allowed low-level attribute type identifiers used in the cull JSON files.",
         "enum": [
            "lBoolT",
            "lDoubleT",
            "lHostT",
            "lIntT",
            "lListT",
            "lLongT",
            "lObjectT",
            "lRefT",
            "lStringT",
            "lTimestampT",
            "lUlong64T",
            "lUlongT"
         ]
      }
   }
}